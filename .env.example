# =============================================================================
# CoreFirst — Environment Variables
# Copy this file to `.env` and fill in only the values you need to override.
#
# NEW: All AI features are DISABLED by default (none). You MUST configure a
# provider (either globally or per-feature) to enable AI capabilities.
#
# Resolution precedence (per feature):
#     <FEATURE>_PROVIDER  >  <CAPABILITY>_PROVIDER  >  GLOBAL_PROVIDER  >  none
# =============================================================================

# =============================================================================
# OPTION A: User-Friendly Global Setup (RECOMMENDED)
# =============================================================================
# Set a single provider and key to power everything. Supported providers will
# automatically use their best-fit models for each feature.
#
# Values: google | openai | anthropic | cli/gemini | cli/claude
# -----------------------------------------------------------------------------

# GLOBAL_PROVIDER=google
# GLOBAL_API_KEY=your_api_key_here

# NOTE: If a global provider doesn't support a capability (e.g. Google doesn't
# currently have native TTS in this SDK), that feature will gracefully
# stay 'none' unless you specifically override it in OPTION B below.


# =============================================================================
# OPTION B: Advanced Custom Mix-and-Match
# =============================================================================
# Use these to override specific capabilities or individual features.
# -----------------------------------------------------------------------------

# --- Capability-level defaults ---
# TEXT_PROVIDER=google
# TEXT_TO_IMAGE_PROVIDER=google
# TEXT_TO_SPEECH_PROVIDER=openai
# SPEECH_TO_TEXT_PROVIDER=openai

# --- Per-feature overrides ---
# TRANSFORM_PROVIDER=cli/gemini   # Use local CLI for logic transformation
# ROLEPLAY_MODEL=gpt-4o-mini     # Use a specific cheaper model for chat

# --- speechEval — LLM "Speech Assessor" ---
# This feature compares user recording (via STT) against target text to
# provide scores and feedback. It's an LLM task, not a voice task.
# SPEECH_EVAL_PROVIDER=


# =============================================================================
# Provider Credentials
# =============================================================================
# You can set provider-specific keys OR use the GLOBAL_API_KEY above.

# GOOGLE_GENERATIVE_AI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# QWEN_API_KEY=


# =============================================================================
# Local & Compatibility Settings
# =============================================================================
# OLLAMA_BASE_URL=http://localhost:11434
# TTS_BASE_URL=http://localhost:8880/v1
# STT_BASE_URL=http://localhost:8000/v1


# =============================================================================
# Storage
# =============================================================================
# COREFIRST_DATA_DIR=./data
