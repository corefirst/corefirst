# =============================================================================
# CoreFirst — fully-local stack for tercel's Mac mini
#
# NEW: You can use GLOBAL_PROVIDER to switch the entire stack at once.
# For this local-first setup, we use specific overrides for each capability.
# =============================================================================

# GLOBAL_PROVIDER=
# GLOBAL_API_KEY=


# -----------------------------------------------------------------------------
# Text — Ollama native API (NOT OpenAI-compat path; uses /api/generate)
# -----------------------------------------------------------------------------
TEXT_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:32b-instruct-q4_K_M

# Quality-critical features — gpt-oss:120b-cloud (no local VRAM cost)
TRANSFORM_MODEL=gpt-oss:120b-cloud
COURSE_GEN_MODEL=gpt-oss:120b-cloud

# Latency-sensitive features — qwen2.5-coder:32b q4 (19GB local)
ROLEPLAY_MODEL=qwen2.5-coder:32b-instruct-q4_K_M

# --- speechEval — LLM "Speech Assessor" (the "Teacher" logic) ---
# Evaluates transcribed user speech against target text for pronunciation
# and logic stress feedback.
SPEECH_EVAL_MODEL=qwen2.5-coder:32b-instruct-q4_K_M


# -----------------------------------------------------------------------------
# TTS — Kokoro via Kokoro-FastAPI sidecar (OpenAI-compatible)
# -----------------------------------------------------------------------------
# Why Kokoro over Orpheus on Ollama:
#   - Kokoro: 82M params, ~250MB ONNX, RTF<0.05 on M-series, OpenAI-compat
#     out of the box. No vocoder pipeline needed.
#   - Orpheus on Ollama: 3B params, requires Orpheus-FastAPI sidecar with
#     SNAC vocoder. More complex to set up; quality only marginally better.
#
# Setup (one-time):
#   docker run -d --name kokoro-fastapi -p 8880:8880 \
#     ghcr.io/remsky/kokoro-fastapi-cpu:latest
#   # or for GPU/MPS variant:
#   # ghcr.io/remsky/kokoro-fastapi-gpu:latest
#
# Verify:
#   curl -X POST http://localhost:8880/v1/audio/speech \
#     -H "Content-Type: application/json" \
#     -d '{"model":"kokoro","input":"hello","voice":"af_sky"}' \
#     --output /tmp/test.wav && open /tmp/test.wav
TTS_PROVIDER=openai
TTS_MODEL=kokoro
TTS_BASE_URL=http://localhost:8880/v1
TTS_VOICE=af_sky                # voices: af_sky, af_bella, af_sarah, am_adam, am_michael, bf_emma, bm_george…


# -----------------------------------------------------------------------------
# STT — faster-whisper-server (OpenAI-compatible)
# -----------------------------------------------------------------------------
# Setup (one-time):
#   docker run -d --name faster-whisper-server -p 8000:8000 \
#     -e WHISPER__MODEL=Systran/faster-whisper-large-v3 \
#     -v ~/.cache/huggingface:/root/.cache/huggingface \
#     fedirz/faster-whisper-server:latest-cpu
#   # for Apple Silicon GPU (Metal): use the -gpu image and add --gpus all
#
# Verify:
#   curl http://localhost:8000/v1/audio/transcriptions \
#     -F "file=@some-audio.wav" -F "model=Systran/faster-whisper-large-v3"
#
# CAVEAT for /api/speech-eval (pronunciation scoring):
#   Whisper auto-corrects accent — a learner saying /v/-as-/f/ may still get
#   transcribed as the "correct" word, hiding pronunciation errors. The
#   logic_stress and pronunciation scores will still work (LLM judges the
#   transcription text), but they'll over-rate users who pronounce poorly.
#   For real pronunciation evaluation you'd need a phoneme-level model
#   (wav2vec2-phoneme); that's Phase 2 work.
STT_PROVIDER=openai
STT_BASE_URL=http://localhost:8000/v1
STT_MODEL=small
STT_API_KEY=local


# -----------------------------------------------------------------------------
# Image — Ollama z-image-turbo via OpenAI-compatible endpoint
# -----------------------------------------------------------------------------
# Ollama exposes /v1/images/generations (OpenAI-compatible, experimental).
# z-image-turbo is a fast image-generation model (~12 GB) that you already
# have pulled. CoreFirst reaches it through the standard `openai` provider
# pointed at Ollama's /v1 endpoint — no Imagen API key needed.
#
# Verify the endpoint works:
#   curl -s http://localhost:11434/v1/images/generations \
#     -H "Authorization: Bearer ollama" \
#     -H "Content-Type: application/json" \
#     -d '{"model":"x/z-image-turbo","prompt":"a cat","size":"1024x1024","response_format":"b64_json"}' \
#     | python3 -c 'import sys,json,base64; d=json.load(sys.stdin); open("/tmp/test.png","wb").write(base64.b64decode(d["data"][0]["b64_json"]))' \
#     && open /tmp/test.png
IMAGE_GEN_PROVIDER=ollama
IMAGE_GEN_MODEL=x/z-image-turbo:latest
IMAGE_GEN_BASE_URL=http://localhost:11434/v1
IMAGE_GEN_API_KEY=ollama                 # Ollama ignores the value but the SDK requires non-empty

# Fallback to Google Imagen — leave empty when using Ollama path above.
# If you ever set IMAGE_GEN_PROVIDER=google, fill in this key to enable it.
# GOOGLE_GENERATIVE_AI_API_KEY=


# =============================================================================
# Operating notes
# =============================================================================
# 1. Service startup order: Ollama → Kokoro-FastAPI → faster-whisper-server →
#    Next.js dev server. The Next process resolves models lazily so each one
#    only matters when the corresponding feature is exercised.
#
# 2. Auto-start on Mac login (recommended): write a launchd plist for each
#    container, or use brew services if you install the binaries non-Docker.
#
# 3. Quick teardown:
#      docker stop kokoro-fastapi faster-whisper-server
#
# 4. Smaller / faster STT alternative: WHISPER__MODEL=Systran/faster-distil-whisper-large-v3
#    (distillation of Large-v3, ~6x faster, accuracy drops <1%).
#
# 5. ollama-ai-provider v1.x can be flaky for `generateObject` (structured
#    output) on heavily-quantized models. If transform / courseGen errors with
#    "NoObjectGeneratedError", switch to the q8_0 Qwen variant you already have:
#      TRANSFORM_MODEL=qwen2.5-coder:32b-instruct-q8_0
#
# 6. Ollama's /v1/images/generations is "experimental" per their docs — only
#    `model` / `prompt` / `size` / `response_format=b64_json` are supported.
#    n>1, quality, style, user → silently ignored or rejected. CoreFirst's
#    course generation only ever requests n=1, so this is fine. If the
#    endpoint disappears in a future Ollama release, set:
#      IMAGE_GEN_PROVIDER=google
#      GOOGLE_GENERATIVE_AI_API_KEY=...
